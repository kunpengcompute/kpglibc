From 21ac228620b325656278b56cec28702bff00403b Mon Sep 17 00:00:00 2001
From: yeweihong <yeweihong@huawei.com>
Date: Wed, 20 May 2026 11:24:51 +0800
Subject: [PATCH] feat: optimize memset for kunpeng950

---
 sysdeps/aarch64/multiarch/Makefile            |   2 +-
 sysdeps/aarch64/multiarch/ifunc-impl-list.c   |   1 +
 sysdeps/aarch64/multiarch/memset.c            |   5 +-
 sysdeps/aarch64/multiarch/memset_kunpeng950.S | 126 ++++++++++++++++++
 4 files changed, 132 insertions(+), 2 deletions(-)
 create mode 100644 sysdeps/aarch64/multiarch/memset_kunpeng950.S

diff --git a/sysdeps/aarch64/multiarch/Makefile b/sysdeps/aarch64/multiarch/Makefile
index 156b23411e..fc95c0f62a 100644
--- a/sysdeps/aarch64/multiarch/Makefile
+++ b/sysdeps/aarch64/multiarch/Makefile
@@ -1,7 +1,7 @@
 ifeq ($(subdir),string)
 sysdep_routines += memcpy_generic memcpy_thunderx memcpy_thunderx2 memcpy_kunpeng950 \
 		   memcpy_falkor memmove_falkor \
-		   memset_generic memset_falkor memset_emag memset_kunpeng \
+		   memset_generic memset_falkor memset_emag memset_kunpeng memset_kunpeng950 \
 		   memchr_generic memchr_nosimd \
 		   strlen_generic strlen_asimd
 endif
diff --git a/sysdeps/aarch64/multiarch/ifunc-impl-list.c b/sysdeps/aarch64/multiarch/ifunc-impl-list.c
index 1ae9a1b344..fc95efe592 100644
--- a/sysdeps/aarch64/multiarch/ifunc-impl-list.c
+++ b/sysdeps/aarch64/multiarch/ifunc-impl-list.c
@@ -55,6 +55,7 @@ __libc_ifunc_impl_list (const char *name, struct libc_ifunc_impl *array,
 	      IFUNC_IMPL_ADD (array, i, memset, (zva_size == 64), __memset_falkor)
 	      IFUNC_IMPL_ADD (array, i, memset, (zva_size == 64), __memset_emag)
 	      IFUNC_IMPL_ADD (array, i, memset, 1, __memset_kunpeng)
+        IFUNC_IMPL_ADD (array, i, memset, sve, __memset_kunpeng950)
 	      IFUNC_IMPL_ADD (array, i, memset, 1, __memset_generic))
   IFUNC_IMPL (i, name, memchr,
 	      IFUNC_IMPL_ADD (array, i, memchr, 1, __memchr_nosimd)
diff --git a/sysdeps/aarch64/multiarch/memset.c b/sysdeps/aarch64/multiarch/memset.c
index ad800bbb95..ecc317a053 100644
--- a/sysdeps/aarch64/multiarch/memset.c
+++ b/sysdeps/aarch64/multiarch/memset.c
@@ -32,9 +32,12 @@ extern __typeof (__redirect_memset) __memset_falkor attribute_hidden;
 extern __typeof (__redirect_memset) __memset_emag attribute_hidden;
 extern __typeof (__redirect_memset) __memset_kunpeng attribute_hidden;
 extern __typeof (__redirect_memset) __memset_generic attribute_hidden;
+extern __typeof (__redirect_memset) __memset_kunpeng950 attribute_hidden;
 
 libc_ifunc (__libc_memset,
-	    IS_KUNPENG920 (midr)
+   IS_KUNPENG950(midr)
+	     ? __memset_kunpeng950
+	    :IS_KUNPENG920 (midr)
 	    ?__memset_kunpeng
 	    : ((IS_FALKOR (midr) || IS_PHECDA (midr)) && zva_size == 64
 	     ? __memset_falkor
diff --git a/sysdeps/aarch64/multiarch/memset_kunpeng950.S b/sysdeps/aarch64/multiarch/memset_kunpeng950.S
new file mode 100644
index 0000000000..c5bb727089
--- /dev/null
+++ b/sysdeps/aarch64/multiarch/memset_kunpeng950.S
@@ -0,0 +1,126 @@
+/* Optimized memset for Huawei Kunpeng 950 processor.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+
+   This file is part of the GNU C Library.
+
+   The GNU C Library is free software; you can redistribute it and/or
+   modify it under the terms of the GNU Lesser General Public
+   License as published by the Free Software Foundation; either
+   version 2.1 of the License, or (at your option) any later version.
+
+   The GNU C Library is distributed in the hope that it will be useful,
+   but WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+   Lesser General Public License for more details.
+
+   You should have received a copy of the GNU Lesser General Public
+   License along with the GNU C Library.  If not, see
+   <https://www.gnu.org/licenses/>.
+*/
+
+#include <sysdep.h>
+
+#define dst_in	x0
+#define val_in	x1
+#define valw_in	w1
+#define cnt		x2
+#define dst_now	x3
+#define dst_end	x4
+#define vlen	x5
+#define tmp1	x6
+#define tmp2	x7
+#define tmp2w	w7
+
+.arch armv8.2-a+sve
+
+ENTRY (__memset_kunpeng950)
+    cntb vlen
+    dup z0.b, valw_in
+	add	dst_end, dst_in, cnt
+    cmp cnt, 256
+    b.hi L(set_256_more)
+
+L(less_64_vl32):
+    whilelo p0.b, xzr, cnt
+    whilelo p1.b, vlen, cnt
+    st1b    z0.b, p0, [dst_in]
+    st1b    z0.b, p1, [dst_in, 1, mul vl]
+    subs cnt, cnt, 64
+	b.hi L(less_128)
+    ret
+
+L(less_128):
+    stp	q0, q0, [dst_end, -64]
+	stp	q0, q0, [dst_end, -32]
+    subs cnt, cnt, 64
+	b.hi L(less_192)
+    ret
+
+L(less_192):
+    stp	q0, q0, [dst_end, -128]
+	stp	q0, q0, [dst_end, -96]
+    subs cnt, cnt, 64
+	b.hi L(less_256)
+    ret
+L(less_256):
+    stp	q0, q0, [dst_in, 64]
+	stp	q0, q0, [dst_in, 96]
+    ret
+
+L(set_256_more):
+	and	valw_in, valw_in, 255
+    and tmp1, dst_in, 63
+	bic	dst_now, dst_in, 63
+    add cnt, cnt, tmp1
+	stp	q0, q0, [dst_in]
+    stp	q0, q0, [dst_in, 32]
+    cmp valw_in, 0
+	b.eq L(try_zva_branch)
+
+	.p2align 4
+L(no_zva):
+	sub	cnt, cnt, 64 + 64
+1:
+	stp q0, q0, [dst_now, 64]
+	stp q0, q0, [dst_now, 96]
+	add dst_now, dst_now, 64
+	subs cnt, cnt, 64
+	b.hi 1b
+2:	stp	q0, q0, [dst_end, -64]
+	stp	q0, q0, [dst_end, -32]
+	ret
+
+	.p2align 4
+L(try_zva_branch):
+    mrs	tmp2, dczid_el0
+	tbnz tmp2w, 4, L(no_zva)
+	and	tmp2w, tmp2w, 15
+	cmp	tmp2w, 4	/* ZVA size is 64 bytes.  */
+	b.ne L(no_zva)
+
+    add dst_now, dst_now, 64
+    subs cnt, cnt, 128+64
+    b.ls L(zva_loop_tail)
+
+L(zva_loop_128):
+	dc	zva, dst_now
+	add	dst_now, dst_now, 64
+	dc	zva, dst_now
+	add	dst_now, dst_now, 64
+	subs cnt, cnt, 128
+	b.hi L(zva_loop_128)
+
+L(zva_loop_tail):
+    add cnt, cnt, 128
+    cmp cnt, 64
+    b.ls L(sve_tail_64)
+    dc	zva, dst_now
+    add dst_now, dst_now, 64
+    sub cnt, cnt, 64
+L(sve_tail_64):
+    whilelo p1.b, xzr, cnt
+	whilelo p2.b, vlen, cnt
+	st1b    z0.b, p1, [dst_now, 0, mul vl]
+	st1b    z0.b, p2, [dst_now, 1, mul vl]
+    ret
+END (__memset_kunpeng950)
-- 
